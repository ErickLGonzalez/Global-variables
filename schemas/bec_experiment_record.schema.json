{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experiment record (BEC/interferometry program, v1.0)",
  "type": "object",
  "required": ["experiment_id", "tier", "evidence_level", "matrix_targets",
               "calibration_route", "m_layer_stipulations",
               "reconstructed_channel", "positivity_certificate",
               "held_out_predictions", "negative_controls",
               "claims_table_category"],
  "properties": {
    "experiment_id": {"type": "string"},
    "tier": {"enum": ["BENCHMARK", "ANALOGUE-REAL", "FUNDAMENTAL-REAL"]},
    "evidence_level": {"enum": ["E0", "E1", "E2", "E3", "E4"]},
    "matrix_targets": {"type": "array", "items": {"type": "object",
      "required": ["block", "column", "role"],
      "properties": {"block": {"type": "string"},
                      "column": {"enum": ["Sym","Pos","Uni","Cau","Cmp","RG","Top","Thm"]},
                      "role": {"enum": ["direct", "methodology"]}}}},
    "calibration_route": {"type": "string",
      "description": "independent channel vs self-consistent; B9-T3 rule: same-data self-consistency is never promotable"},
    "m_layer_stipulations": {"type": "array", "items": {"type": "string"}},
    "dimensionless_observables": {"type": "array"},
    "prepared_state": {"type": "object"},
    "control_parameters": {"type": "object"},
    "reconstructed_channel": {"type": "object"},
    "positivity_certificate": {"type": "object"},
    "causality_certificate": {"type": "object"},
    "composition_model": {"type": "object"},
    "held_out_predictions": {"type": "array"},
    "negative_controls": {"type": "array"},
    "provenance": {"type": "object",
      "properties": {"source": {"type": "string"}, "checksum": {"type": "string"},
                      "retrieval_date": {"type": "string"}}},
    "claims_table_category": {"enum": ["known theorem", "recovered known result",
      "empirical consistency", "framework prediction",
      "novel prospective prediction", "speculative interpretation"]},
    "epistemic_status": {"type": "string"}
  }
}
